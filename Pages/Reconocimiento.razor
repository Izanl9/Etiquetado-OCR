@page "/reconocimiento"
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@using QuestPDF.Previewer
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@inject StockService StockService
@inject IJSRuntime JSRuntime

<div class="container">
    <h3>Escaneo de Albarán</h3>
    
    <button class="btn btn-primary w-100 mb-3" @onclick="CapturarAlbaran">
        <i class="oi oi-camera"></i> Escanear Albarán
    </button>

    @if (productosDetectados.Any())
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-success text-white">Productos Detectados</div>
            <ul class="list-group list-group-flush">
                @foreach (var p in productosDetectados)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        @p.Nombre <span>x@p.Cantidad</span>
                    </li>
                }
            </ul>
        </div>

        <button class="btn btn-outline-danger w-100" @onclick="GenerarPdfEtiquetas">
            <i class="oi oi-document"></i> Generar PDF de Etiquetas
        </button>
    }
</div>

@code {
    private List<Producto> productosDetectados = new();

    private async Task CapturarAlbaran()
    {
        try
        {
            var photo = await MediaPicker.Default.CapturePhotoAsync();
            if (photo == null) return;

            // Aquí iría el procesamiento ML Kit. 
            // Por ahora simulamos la extracción de texto del OCR:
            productosDetectados = new List<Producto>
            {
                new Producto { Nombre = "Caja Tornillos M8", Cantidad = 10 },
                new Producto { Nombre = "Arandelas Acero", Cantidad = 5 }
            };

            // Actualizamos el inventario local automáticamente
            await StockService.ActualizarDesdeAlbaran(productosDetectados);
            
            await JSRuntime.InvokeVoidAsync("alert", "Inventario actualizado y albarán procesado.");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
    }

    private async Task GenerarPdfEtiquetas()
    {
        try
        {
            // Configurar la licencia de QuestPDF (es gratis para uso comunitario)
            QuestPDF.Settings.License = LicenseType.Community;

            var document = Document.Create(container =>
            {
                foreach (var prod in productosDetectados)
                {
                    // Crear una etiqueta por cada unidad de la cantidad
                    for (int i = 0; i < prod.Cantidad; i++)
                    {
                        container.Page(page =>
                        {
                            // Tamaño típico de etiqueta térmica (ej: 4x2 pulgadas)
                            page.Size(288, 144); 
                            page.Margin(10);
                            page.Background(Colors.White);
                            page.DefaultTextStyle(x => x.FontSize(12).FontFamily(Fonts.Verdana));

                            page.Content().Column(col =>
                            {
                                col.Item().Text("PRODUCTO").FontSize(10).SemiBold().FontColor(Colors.Grey.Medium);
                                col.Item().Text(prod.Nombre).FontSize(16).Bold();
                                col.Item().PaddingTop(5).LineHorizontal(1);
                                col.Item().PaddingTop(5).Text($"Etiqueta {i + 1} de {prod.Cantidad}").FontSize(8);
                                
                                // Aquí podrías añadir un código de barras en el futuro
                                col.Item().AlignCenter().Text("|| |||| ||| ||||").FontSize(20); 
                            });
                        });
                    }
                }
            });

            // Guardar el PDF en la carpeta temporal del móvil
            string fileName = $"Etiquetas_{DateTime.Now:yyyyMMddHHmm}.pdf";
            string filePath = Path.Combine(FileSystem.CacheDirectory, fileName);
            
            document.GeneratePdf(filePath);

            // Compartir el archivo automáticamente para que el usuario pueda imprimirlo o enviarlo
            await Share.Default.RequestAsync(new ShareFileRequest
            {
                Title = "Imprimir Etiquetas",
                File = new ShareFile(filePath)
            });
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error al generar PDF: " + ex.Message);
        }
    }
}