@page "/reconocimiento"
@using EtiquetadoAuto.Models
@using EtiquetadoAuto.Services
@using Microsoft.Maui.Media
@using Microsoft.JSInterop
@using System.Threading.Tasks
@inject IJSRuntime JSRuntime
@inject DatabaseService DB
@inject PdfService GeneradorPdf

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-0"><i class="oi oi-camera"></i> Escaneo de Albarán</h4>
        </div>
        <div class="card-body text-center">
            <p class="text-secondary">Capture el albarán para procesar los purgadores y válvulas.</p>
            
            @if (isProcessing)
            {
                <div class="my-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 fw-bold text-primary">@estadoMensaje</p>
                </div>
            }
            else
            {
                <button class="btn btn-success btn-lg w-100 py-3 shadow-sm mb-4" @onclick="CapturarAlbaran">
                    <i class="oi oi-camera"></i> ESCANEAR AHORA
                </button>
            }

            @if (productosDetectados.Any())
            {
                <div class="text-start">
                    <h5 class="mb-3">Material Detectado:</h5>
                    <div class="list-group shadow-sm mb-4">
                        @foreach (var prod in productosDetectados)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="d-block fw-bold">@prod.Nombre</span>
                                    <small class="text-muted">ID Temporal: @prod.Codigo</small>
                                </div>
                                <span class="badge bg-primary rounded-pill px-3 py-2">Cant: @prod.Cantidad</span>
                            </div>
                        }
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-lg" @onclick="ProcesarTodo">
                            <i class="oi oi-check"></i> CONFIRMAR E IMPRIMIR
                        </button>
                        <button class="btn btn-light btn-sm text-danger" @onclick="LimpiarEscaneo">
                            Descartar escaneo
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    public class InfoLinea 
    {
        public string Texto { get; set; } = "";
        public int Y { get; set; }
    }

    private List<Producto> productosDetectados = new();
    private bool isProcessing = false;
    private string estadoMensaje = "";

    private async Task CapturarAlbaran()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Iniciando cámara...";
            StateHasChanged(); 

            var photo = await MediaPicker.CapturePhotoAsync();
            if (photo == null) return;

            estadoMensaje = "Analizando texto...";
            StateHasChanged(); 

            #if ANDROID
            var javaFile = new Java.IO.File(photo.FullPath);
            var imageUri = Android.Net.Uri.FromFile(javaFile);
            var image = Xamarin.Google.MLKit.Vision.Common.InputImage.FromFilePath(Android.App.Application.Context, imageUri);
            
            var options = Xamarin.Google.MLKit.Vision.Text.Latin.TextRecognizerOptions.DefaultOptions;
            var recognizer = Xamarin.Google.MLKit.Vision.Text.TextRecognition.GetClient(options);
            
            var tcs = new TaskCompletionSource<object>();
            recognizer.Process(image)
                .AddOnSuccessListener(new OnSuccessImplementation(tcs))
                .AddOnFailureListener(new OnFailureImplementation(tcs));

            var resultObj = await tcs.Task;
            var visionText = (Xamarin.Google.MLKit.Vision.Text.Text)resultObj;
            
            ProcesarTextoEspacial(visionText);
            #else
            await JSRuntime.InvokeVoidAsync("alert", "Funcionalidad solo disponible en Android.");
            #endif
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    #if ANDROID
    private void ProcesarTextoEspacial(Xamarin.Google.MLKit.Vision.Text.Text visionText)
    {
        productosDetectados.Clear();
        var lineasLimpias = new List<InfoLinea>();

        // 1. Filtrado agresivo antes de agrupar
        foreach (var block in visionText.TextBlocks)
        {
            foreach (var line in block.Lines)
            {
                string txt = line.Text.Trim();
                string minus = txt.ToLower()
                    .Replace("à", "a").Replace("á", "a").Replace("è", "e").Replace("é", "e")
                    .Replace("í", "i").Replace("ò", "o").Replace("ó", "o").Replace("ú", "u");

                // Filtro de "Basura" de cabecera y pie de página
                if (minus.Contains("albara") || minus.Contains("seditesa") || minus.Contains("sint") || 
                    minus.Contains("izan") || minus.Contains("lecina") || minus.Contains("carrer") || 
                    minus.Contains("carer") || minus.Contains("telf") || minus.Contains("fecha") || 
                    minus.Contains("data") || minus.Contains("quantitat") || minus.Contains("descripci") || 
                    minus.Contains("www") || minus.Contains("@") || minus.Contains("fictici") || 
                    minus.Contains("nro") || minus.Contains("comanda"))
                {
                    continue;
                }

                // Ignorar números de serie largos (8+ dígitos)
                if (System.Text.RegularExpressions.Regex.IsMatch(txt.Replace(" ", ""), "\\d{8,}")) continue;

                lineasLimpias.Add(new InfoLinea { Texto = txt, Y = line.BoundingBox.CenterY() });
            }
        }

        if (!lineasLimpias.Any()) return;

        // 2. Agrupación por filas (Margen de 40px para asegurar que el número y el texto se peguen)
        var filas = lineasLimpias
            .OrderBy(l => l.Y)
            .GroupBy(l => Math.Round(l.Y / 40.0) * 40.0)
            .ToList();

        foreach (var fila in filas)
        {
            int cantidad = 0;
            string nombre = "";

            foreach (var item in fila)
            {
                // Si es un número solo (1-3 cifras), es la cantidad
                var matchCant = System.Text.RegularExpressions.Regex.Match(item.Texto.Trim(), "^(\\d{1,3})$");
                if (matchCant.Success)
                {
                    cantidad = int.Parse(matchCant.Groups[1].Value);
                }
                else if (item.Texto.Length > 5)
                {
                    // Es el nombre del producto
                    nombre = System.Text.RegularExpressions.Regex.Replace(item.Texto, "[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\\s\\.\\-®]", "").Trim();
                }
            }

            // Solo añadimos si parece un producto real
            if (!string.IsNullOrWhiteSpace(nombre) && nombre.Length > 6)
            {
                productosDetectados.Add(new Producto {
                    Nombre = nombre,
                    Cantidad = cantidad > 0 ? cantidad : 1,
                    Codigo = "OCR-" + DateTime.Now.ToString("mmss")
                });
            }
        }
    }
    #endif

    private async Task ProcesarTodo()
    {
        try
        {
            isProcessing = true;
            estadoMensaje = "Guardando datos...";
            StateHasChanged();

            foreach (var prod in productosDetectados)
                await DB.GuardarProducto(prod);

            string path = GeneradorPdf.GenerarEtiquetas(productosDetectados);
            await Launcher.Default.OpenAsync(new OpenFileRequest {
                Title = "PDF de Etiquetas",
                File = new ReadOnlyFile(path)
            });

            LimpiarEscaneo();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error final: " + ex.Message);
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void LimpiarEscaneo() => productosDetectados.Clear();

#if ANDROID
    public class OnSuccessImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnSuccessListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnSuccessImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnSuccess(Java.Lang.Object result) => _tcs.SetResult(result);
    }

    public class OnFailureImplementation : Java.Lang.Object, Android.Gms.Tasks.IOnFailureListener
    {
        private readonly TaskCompletionSource<object> _tcs;
        public OnFailureImplementation(TaskCompletionSource<object> tcs) => _tcs = tcs;
        public void OnFailure(Java.Lang.Exception e) => _tcs.SetException(e);
    }
#endif
}