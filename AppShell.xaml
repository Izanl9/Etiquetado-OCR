<?xml version="1.0" encoding="UTF-8" ?>
<Shell Shell.TabBarBackgroundColor="White"
       Shell.TabBarForegroundColor="#2196F3"
       x:Class="EtiquetadoAuto.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:local="clr-namespace:EtiquetadoAuto"
       x:Class="EtiquetadoAuto.AppShell">

    <TabBar>
        <Tab Title="Escáner">
            <ShellContent ContentTemplate="{DataTemplate local:ScannerPage}" />
        </Tab>
        <Tab Title="Inventario">
            <ShellContent ContentTemplate="{DataTemplate local:InventoryPage}" />
        </Tab>
    </TabBar>
</Shell>