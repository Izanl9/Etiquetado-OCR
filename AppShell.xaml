<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="EtiquetadoAuto.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:EtiquetadoAuto"
       x:DataType="local:AppShell"
       Shell.TabBarBackgroundColor="White"
       Shell.TabBarForegroundColor="#2196F3"
       Shell.TabBarUnselectedColor="#757575"
       Shell.TitleColor="Black"
       Shell.BackgroundColor="#2196F3">

    <TabBar>
        <Tab Title="Escáner">
            <ShellContent ContentTemplate="{DataTemplate local:Pages.ScannerPage}" />
        </Tab>
        <Tab Title="Inventario">
            <ShellContent ContentTemplate="{DataTemplate local:Pages.InventoryPage}" />
        </Tab>
    </TabBar>
</Shell>